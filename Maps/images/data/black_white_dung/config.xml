<root a="32" b="32" shadow="32" enable_printing="on" pa="200" pb="200" title="Black & white">
  <list name="modes">
    <mode name="floor">
      <list name="groups">
        <group title="Outline" folder="floor/wire/" x="0" y="0" blur="off" shadow="off" rotate="off"/>	  
        <group title="Low ink" folder="floor/econom/" x="0" y="0" blur="off" shadow="off" rotate="off"/>
        <group title="Detailed" folder="floor/floor/" x="0" y="0" blur="off" shadow="off" rotate="off"/>
      </list>
    </mode>
    <mode name="walls">
      <list name="groups">
        <group title="Outline" folder="wall/wire/" x="0" y="0" blur="off" shadow="off" rotate="off"/>	  
        <group title="Detailed" folder="wall/detail/" x="0" y="0" blur="off" shadow="off" rotate="off"/>
      </list>
    </mode>
    <mode name="terrain">
      <list name="groups"/>
    </mode>
    <mode name="obstacles">
      <list name="groups">
        <group title="Outline" folder="decor/wire/" x="0" y="0" blur="off" shadow="off" rotate="off"/>
        <group title="Detailed" folder="decor/cracks/" x="0" y="0" blur="off" shadow="off" rotate="off"/>
      </list>
    </mode>
    <mode name="decor">
      <list name="groups"/>
    </mode>
    <mode name="plants">
      <list name="groups"/>
    </mode>
  </list>
</root>