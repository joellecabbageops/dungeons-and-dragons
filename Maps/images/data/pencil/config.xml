<root title="Pencil" a="32" b="32" shadow="30" enable_printing="off" pa="200" pb="200">
  <list name="modes">
    <mode name="walls">
      <list name="groups">
        <group title="Doors" folder="Doors/" tilex="1" tiley="1" x="0" y="0" blur="on" shadow="off" rotate="off"/>
        <group title="Walls" folder="Walls/" tilex="1" tiley="1" x="0" y="0" blur="on" shadow="off" rotate="off"/>
        <group title="Windows" folder="Windows/" tilex="1" tiley="1" x="0" y="0" blur="on" shadow="off" rotate="off"/>
      </list>
    </mode>
    <mode name="decor">
      <list name="groups"/>
    </mode>
    <mode name="obstacles">
      <list name="groups">
        <group title="Compass" folder="Objects/Compass/" tilex="1" tiley="1" x="0" y="0" blur="off" shadow="on" rotate="off"/>
        <group title="Stairs" folder="Objects/Stairs/" tilex="1" tiley="1" x="0" y="0" blur="off" shadow="on" rotate="off"/>
      </list>
    </mode>
    <mode name="floor">
      <list name="groups">
        <group title="Floors" folder="Floors/" tilex="1" tiley="1" x="0" y="0" blur="off" shadow="on" rotate="off"/>
      </list>
    </mode>
    <mode name="terrain">
      <list name="groups"/>
    </mode>
    <mode name="plants">
      <list name="groups"/>
    </mode>
  </list>
</root>